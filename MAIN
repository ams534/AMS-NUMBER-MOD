<body>
<canvas id="matrix"></canvas>

<div class="container">
  <!-- ---------- Login Box ---------- -->
  <div id="loginBox" class="active">
    <h2>ENTER PASSWORD</h2>
    <input type="password" id="passwordInput" placeholder="Enter Password" />
    <br />
    <button onclick="login()">Login</button>
    <div id="loginMsg" style="margin-top:10px;color:red;"></div>
  </div>

  <!-- ---------- Main Box ---------- -->
  <div id="mainBox">
    <h2>ENTER PERIOD NUMBER</h2>
    <input type="text" id="periodInput" placeholder="Enter Period Number" />
    <br />
    <button onclick="generatePrediction()">Get Number</button>
    <div class="result" id="output"></div>
  </div>
</div>

<script>
/* ---------- Matrix background animation ---------- */
const canvas = document.getElementById("matrix");
const ctx = canvas.getContext("2d");
canvas.height = window.innerHeight;
canvas.width = window.innerWidth;
const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ123456789@#$%^&*()*&^%";
const fontSize = 14;
const columns = canvas.width / fontSize;
const drops = Array(Math.floor(columns)).fill(1);

function drawMatrix() {
  ctx.fillStyle = "rgba(0, 0, 0, 0.05)";
  ctx.fillRect(0, 0, canvas.width, canvas.height);
  ctx.fillStyle = "#0F0";
  ctx.font = fontSize + "px monospace";
  for (let i = 0; i < drops.length; i++) {
    const text = letters.charAt(Math.floor(Math.random() * letters.length));
    ctx.fillText(text, i * fontSize, drops[i] * fontSize);
    if (drops[i] * fontSize > canvas.height && Math.random() > 0.975)
      drops[i] = 0;
    drops[i]++;
  }
}
setInterval(drawMatrix, 33);

/* ---------- Login system ---------- */
function login() {
  const pass = document.getElementById("passwordInput").value.trim();
  if (pass === "12345") {
    document.getElementById("loginBox").classList.remove("active");
    document.getElementById("mainBox").classList.add("active");
  } else {
    document.getElementById("loginMsg").textContent = "Wrong Password!";
  }
}

/* ---------- Prediction system ---------- */
function generatePrediction() {
  const period = document.getElementById("periodInput").value.trim();
  if (period === "") {
    document.getElementById("output").innerHTML =
      "<span style='color:red'>Please enter a period number.</span>";
    return;
  }

  // deterministic formula: always same result for same period
  let sum = 0;
  for (let i = 0; i < period.length; i++) {
    sum += period.charCodeAt(i);
  }
  const number = sum % 10;
  const type = number < 5 ? "SMALL" : "BIG";
  const colorClass = type === "BIG" ? "big" : "small";

  document.getElementById("output").innerHTML = `
    <p>PERIOD: <span>${period}</span></p>
    <p>RESULT → <span>${number}</span> <span class="${colorClass}">${type}</span></p>
  `;
}
</script>
</body>
